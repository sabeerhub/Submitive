VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Free API key from tiny.cloud - needed for the rich-text field in submission
# forms. Sign up free at https://www.tiny.cloud/auth/signup/
VITE_TINYMCE_API_KEY=

# Leave blank for local dev (uses the Vite proxy to localhost:4000).
# In production (Vercel), set this to your deployed backend's URL, e.g.
# https://submitiv-backend.onrender.com/api
VITE_API_BASE_URL=

# Anon/public key only — used exclusively to consume signed storage upload
# URLs on the public submission page. Never grants table access (RLS denies
# all direct client access to tenant data; only the backend's service role
# talks to Postgres).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=submissions
