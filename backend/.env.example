# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Firebase Admin (identity verification only — no app data stored in Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Supabase (Postgres + Storage)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=submissions

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@submitiv.app

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Shared secret for the deadline-reminder cron endpoint. Generate any random
# string (e.g. `openssl rand -hex 32`) and use the same value when
# configuring your external scheduler (see routes/cron.ts).
CRON_SECRET=
